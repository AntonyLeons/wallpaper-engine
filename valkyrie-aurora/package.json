{
  "name": "wallpaper-engine-valkyrie-aurora",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "node -e \"import('fs').then(fs => { fs.copyFileSync('project.json', 'dist/project.json'); if (fs.existsSync('preview.gif')) fs.copyFileSync('preview.gif', 'dist/preview.gif'); })\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
